@page "/"
@rendermode InteractiveServer
@inject MesApiClient ApiClient

<PageTitle>MES 首页</PageTitle>

<h3 class="page-title">MES 工站模拟系统</h3>

<Card>
    <HeaderTemplate>
        <strong>API 连接状态</strong>
    </HeaderTemplate>
    <BodyTemplate>
        @if (_checking)
        {
            <p>正在检测 MES API...</p>
        }
        else if (_apiHealthy)
        {
            <p class="status-ok"><i class="fa-solid fa-circle-check"></i> API 已连接（@_stationCount 个工站）</p>
        }
        else
        {
            <p class="status-error"><i class="fa-solid fa-circle-xmark"></i> 无法连接 API，请先启动 <code>dotnet run --project src/backend/MES.Api</code></p>
        }
    </BodyTemplate>
</Card>

<Card class="mt-3">
    <HeaderTemplate>
        <strong>快速入口</strong>
    </HeaderTemplate>
    <BodyTemplate>
        <div class="d-flex gap-2 flex-wrap">
            <Button Color="Color.Primary" Icon="fa-solid fa-industry" OnClick="@(() => Navigation.NavigateTo("/station"))">
                进入工站工作台
            </Button>
            <Button Color="Color.Secondary" Icon="fa-solid fa-clipboard-list" OnClick="@(() => Navigation.NavigateTo("/work-orders"))">
                创建工单
            </Button>
            <Button Color="Color.Info" Icon="fa-solid fa-search" OnClick="@(() => Navigation.NavigateTo("/traceability"))">
                SN 追溯
            </Button>
        </div>
    </BodyTemplate>
</Card>

<Card class="mt-3">
    <HeaderTemplate>
        <strong>演示流程（种子数据 PCB-A）</strong>
    </HeaderTemplate>
    <BodyTemplate>
        <div class="demo-steps">
            <ol>
                <li>创建工单 <code>WO-DEMO-001</code>，产品 <code>PCB-A</code></li>
                <li>工站 <code>ST-ASSY-01</code>：SN 过站</li>
                <li>工站 <code>ST-ICT-01</code>：过站进站 → 模拟 PASS</li>
                <li>工站 <code>ST-FCT-01</code>：过站进站 → 模拟 PASS → SN 完成</li>
                <li>尝试跳站至 <code>ST-FCT-01</code> 验证 <code>MES-4002</code> 拦截</li>
            </ol>
        </div>
        <p class="station-hint mb-0">
            双终端启动：API <code>dotnet run --project src/backend/MES.Api</code>；
            前端 <code>dotnet run --project src/frontend/MES.Web</code>
        </p>
    </BodyTemplate>
</Card>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private bool _checking = true;
    private bool _apiHealthy;
    private int _stationCount;

    protected override async Task OnInitializedAsync()
    {
        _apiHealthy = await ApiClient.CheckHealthAsync();
        if (_apiHealthy)
        {
            var stations = await ApiClient.GetStationsAsync();
            _stationCount = stations.Count;
        }

        _checking = false;
    }
}
