@page "/spc"
@inject MesApiClient ApiClient

<PageTitle>SPC 与看板</PageTitle>

<h4>SPC 总览</h4>
<div class="mb-3">
    <button class="btn btn-primary" @onclick="RefreshAsync" disabled="@_loading">刷新</button>
    @if (_loading)
    {
        <span class="ms-2 text-muted">加载中...</span>
    }
</div>

@if (_summary is not null)
{
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">样本数</div><div class="h4">@_summary.SampleCount</div></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">良率</div><div class="h4">@(_summary.YieldRate.ToString("P2"))</div></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">一次通过率</div><div class="h4">@(_summary.FirstPassYieldRate.ToString("P2"))</div></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">窗口</div><div class="small">@_summary.WindowStart.LocalDateTime ~ @_summary.WindowEnd.LocalDateTime</div></div></div>
        </div>
    </div>

    <h5>指标统计</h5>
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>指标</th>
                <th>样本</th>
                <th>均值</th>
                <th>最小值</th>
                <th>最大值</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var metric in _summary.Metrics)
            {
                <tr>
                    <td>@metric.MetricName</td>
                    <td>@metric.Count</td>
                    <td>@metric.Mean.ToString("F4")</td>
                    <td>@metric.Min.ToString("F4")</td>
                    <td>@metric.Max.ToString("F4")</td>
                </tr>
            }
        </tbody>
    </table>
}

<h5 class="mt-4">最新告警</h5>
@if (_dashboard is not null)
{
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                <th>时间</th>
                <th>SN</th>
                <th>工站</th>
                <th>指标</th>
                <th>值</th>
                <th>信息</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var alarm in _dashboard.LatestAlarms)
            {
                <tr>
                    <td>@alarm.OccurredAt.LocalDateTime</td>
                    <td>@alarm.Sn</td>
                    <td>@alarm.StationCode</td>
                    <td>@alarm.MetricName</td>
                    <td>@alarm.MetricValue.ToString("F4")</td>
                    <td>@alarm.Message</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private SpcSummaryResponse? _summary;
    private DashboardRealtimeResponse? _dashboard;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        try
        {
            _summary = await ApiClient.GetSpcSummaryAsync();
            _dashboard = await ApiClient.GetDashboardRealtimeAsync();
        }
        finally
        {
            _loading = false;
        }
    }
}
