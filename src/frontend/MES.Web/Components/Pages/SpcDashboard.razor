@page "/spc"
@inject MesApiClient ApiClient
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<PageTitle>SPC 与看板</PageTitle>

<h4>SPC 总览</h4>
<div class="mb-2">
    <span class="badge @GetConnectionBadgeClass()">@GetConnectionBadgeText()</span>
    @if (!string.IsNullOrWhiteSpace(_connectionMessage))
    {
        <span class="ms-2 small text-muted">@_connectionMessage</span>
    }
    @if (_lastRealtimeAt is not null)
    {
        <span class="ms-2 small text-muted">最后推送：@_lastRealtimeAt.Value.LocalDateTime</span>
    }
</div>
<div class="mb-3">
    <button class="btn btn-primary" @onclick="RefreshAsync" disabled="@_loading">刷新</button>
    @if (_loading)
    {
        <span class="ms-2 text-muted">加载中...</span>
    }
</div>

@if (_summary is not null)
{
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">样本数</div><div class="h4">@_summary.SampleCount</div></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">良率</div><div class="h4">@(_summary.YieldRate.ToString("P2"))</div></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">一次通过率</div><div class="h4">@(_summary.FirstPassYieldRate.ToString("P2"))</div></div></div>
        </div>
        <div class="col-md-3">
            <div class="card"><div class="card-body"><div class="text-muted">窗口</div><div class="small">@_summary.WindowStart.LocalDateTime ~ @_summary.WindowEnd.LocalDateTime</div></div></div>
        </div>
    </div>

    <h5>指标统计</h5>
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>指标</th>
                <th>样本</th>
                <th>均值</th>
                <th>最小值</th>
                <th>最大值</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var metric in _summary.Metrics)
            {
                <tr>
                    <td>@metric.MetricName</td>
                    <td>@metric.Count</td>
                    <td>@metric.Mean.ToString("F4")</td>
                    <td>@metric.Min.ToString("F4")</td>
                    <td>@metric.Max.ToString("F4")</td>
                </tr>
            }
        </tbody>
    </table>
}

<h5 class="mt-4">最新告警</h5>
@if (_dashboard is not null)
{
    <table class="table table-bordered table-sm">
        <thead>
            <tr>
                <th>时间</th>
                <th>SN</th>
                <th>工站</th>
                <th>指标</th>
                <th>值</th>
                <th>信息</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var alarm in _dashboard.LatestAlarms)
            {
                <tr>
                    <td>@alarm.OccurredAt.LocalDateTime</td>
                    <td>@alarm.Sn</td>
                    <td>@alarm.StationCode</td>
                    <td>@alarm.MetricName</td>
                    <td>@alarm.MetricValue.ToString("F4")</td>
                    <td>@alarm.Message</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private SpcSummaryResponse? _summary;
    private DashboardRealtimeResponse? _dashboard;
    private bool _loading;
    private HubConnection? _hubConnection;
    private string? _connectionState;
    private string? _connectionMessage;
    private DateTimeOffset? _lastRealtimeAt;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        await InitializeRealtimeAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        try
        {
            _summary = await ApiClient.GetSpcSummaryAsync();
            _dashboard = await ApiClient.GetDashboardRealtimeAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task InitializeRealtimeAsync()
    {
        var hubUrl = new Uri(ApiClient.BaseAddress, "/hubs/dashboard");

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<DashboardRealtimeResponse>("dashboard.updated", async payload =>
        {
            _dashboard = payload;
            _summary = payload.Summary;
            _lastRealtimeAt = DateTimeOffset.Now;
            _connectionState = "Connected";
            _connectionMessage = "收到实时更新";
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.Reconnecting += _ =>
        {
            _connectionState = "Reconnecting";
            _connectionMessage = "连接中断，正在自动重连...";
            return InvokeAsync(StateHasChanged);
        };

        _hubConnection.Reconnected += _ =>
        {
            _connectionState = "Connected";
            _connectionMessage = "重连成功";
            return InvokeAsync(StateHasChanged);
        };

        _hubConnection.Closed += _ =>
        {
            _connectionState = "Closed";
            _connectionMessage = "连接已断开，请点击刷新或稍后重试。";
            return InvokeAsync(StateHasChanged);
        };

        try
        {
            await _hubConnection.StartAsync();
            _connectionState = "Connected";
            _connectionMessage = "实时连接已建立";
        }
        catch (Exception ex)
        {
            _connectionState = "Closed";
            _connectionMessage = $"实时连接失败：{ex.Message}";
        }
    }

    private string GetConnectionBadgeText() => _connectionState switch
    {
        "Connected" => "实时已连接",
        "Reconnecting" => "重连中",
        "Closed" => "已断开",
        _ => "未连接"
    };

    private string GetConnectionBadgeClass() => _connectionState switch
    {
        "Connected" => "bg-success",
        "Reconnecting" => "bg-warning text-dark",
        "Closed" => "bg-danger",
        _ => "bg-secondary"
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
