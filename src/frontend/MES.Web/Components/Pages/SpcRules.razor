@page "/spc-rules"
@inject MesApiClient ApiClient

<PageTitle>SPC 规则管理</PageTitle>

<h4>SPC 规则管理</h4>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label">筛选产品</label>
                <input class="form-control" @bind="_filterProductCode" placeholder="例如 PCB-A" />
            </div>
            <div class="col-md-3">
                <label class="form-label">筛选工站</label>
                <input class="form-control" @bind="_filterStationCode" placeholder="例如 ST-ICT-01" />
            </div>
            <div class="col-md-6">
                <button class="btn btn-outline-primary me-2" @onclick="ApplyFilterAsync" disabled="@_loading">应用筛选</button>
                <button class="btn btn-outline-secondary" @onclick="ClearFilterAsync" disabled="@_loading">清空筛选</button>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-2">
                <label class="form-label">规则编码</label>
                <input class="form-control" @bind="_create.RuleCode" />
            </div>
            <div class="col-md-2">
                <label class="form-label">指标</label>
                <input class="form-control" @bind="_create.MetricName" />
            </div>
            <div class="col-md-2">
                <label class="form-label">产品</label>
                <input class="form-control" @bind="_create.ProductCode" />
            </div>
            <div class="col-md-2">
                <label class="form-label">工站</label>
                <input class="form-control" @bind="_create.StationCode" />
            </div>
            <div class="col-md-2">
                <label class="form-label">下限</label>
                <input class="form-control" type="number" step="0.0001" @bind="_createLowerText" />
            </div>
            <div class="col-md-2">
                <label class="form-label">上限</label>
                <input class="form-control" type="number" step="0.0001" @bind="_createUpperText" />
            </div>
        </div>
        <div class="mt-3">
            <button class="btn btn-primary" @onclick="CreateRuleAsync" disabled="@_loading">新增规则</button>
            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <span class="ms-3 text-muted">@_message</span>
            }
        </div>
    </div>
</div>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>规则编码</th>
            <th>指标</th>
            <th>产品</th>
            <th>工站</th>
            <th>下限</th>
            <th>上限</th>
            <th>启用</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in _rules)
        {
            <tr>
                <td>@item.RuleCode</td>
                @if (_editingRuleCode == item.RuleCode)
                {
                    <td><input class="form-control form-control-sm" @bind="_edit.MetricName" /></td>
                    <td><input class="form-control form-control-sm" @bind="_edit.ProductCode" /></td>
                    <td><input class="form-control form-control-sm" @bind="_edit.StationCode" /></td>
                    <td><input class="form-control form-control-sm" type="number" step="0.0001" @bind="_editLowerText" /></td>
                    <td><input class="form-control form-control-sm" type="number" step="0.0001" @bind="_editUpperText" /></td>
                    <td><input type="checkbox" class="form-check-input" @bind="_edit.IsActive" /></td>
                }
                else
                {
                    <td>@item.MetricName</td>
                    <td>@item.ProductCode</td>
                    <td>@item.StationCode</td>
                    <td>@(item.LowerLimit?.ToString("F4") ?? "-")</td>
                    <td>@(item.UpperLimit?.ToString("F4") ?? "-")</td>
                    <td>@(item.IsActive ? "是" : "否")</td>
                }
                <td>
                    @if (_editingRuleCode == item.RuleCode)
                    {
                        <button class="btn btn-success btn-sm me-1" @onclick="() => SaveEditAsync(item.RuleCode)" disabled="@_loading">保存</button>
                        <button class="btn btn-secondary btn-sm me-1" @onclick="CancelEdit" disabled="@_loading">取消</button>
                    }
                    else
                    {
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => StartEdit(item)" disabled="@_loading">编辑</button>
                    }
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteRuleAsync(item.RuleCode)" disabled="@_loading">删除</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private readonly CreateSpcRuleRequest _create = new();
    private readonly UpdateSpcRuleRequest _edit = new();
    private readonly List<SpcRuleResponse> _rules = [];
    private bool _loading;
    private string? _message;
    private string? _createLowerText;
    private string? _createUpperText;
    private string? _editLowerText;
    private string? _editUpperText;
    private string? _editingRuleCode;
    private string? _filterProductCode;
    private string? _filterStationCode;

    protected override async Task OnInitializedAsync()
    {
        await LoadRulesAsync();
    }

    private async Task LoadRulesAsync()
    {
        _loading = true;
        try
        {
            var rules = await ApiClient.GetSpcRulesAsync(_filterProductCode, _filterStationCode);
            _rules.Clear();
            _rules.AddRange(rules);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ApplyFilterAsync()
    {
        await LoadRulesAsync();
    }

    private async Task ClearFilterAsync()
    {
        _filterProductCode = string.Empty;
        _filterStationCode = string.Empty;
        await LoadRulesAsync();
    }

    private async Task CreateRuleAsync()
    {
        _create.LowerLimit = ParseNullableDouble(_createLowerText);
        _create.UpperLimit = ParseNullableDouble(_createUpperText);

        _loading = true;
        try
        {
            var result = await ApiClient.CreateSpcRuleAsync(_create);
            _message = $"{result.Code} - {result.Message}";

            if (result.Success)
            {
                _create.RuleCode = string.Empty;
                _create.MetricName = string.Empty;
                _create.ProductCode = string.Empty;
                _create.StationCode = string.Empty;
                _createLowerText = string.Empty;
                _createUpperText = string.Empty;
                await LoadRulesAsync();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task DeleteRuleAsync(string ruleCode)
    {
        _loading = true;
        try
        {
            var result = await ApiClient.DeleteSpcRuleAsync(ruleCode);
            _message = $"{result.Code} - {result.Message}";
            await LoadRulesAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartEdit(SpcRuleResponse rule)
    {
        _editingRuleCode = rule.RuleCode;
        _edit.MetricName = rule.MetricName;
        _edit.ProductCode = rule.ProductCode;
        _edit.StationCode = rule.StationCode;
        _edit.IsActive = rule.IsActive;
        _editLowerText = rule.LowerLimit?.ToString();
        _editUpperText = rule.UpperLimit?.ToString();
    }

    private void CancelEdit()
    {
        _editingRuleCode = null;
        _editLowerText = null;
        _editUpperText = null;
    }

    private async Task SaveEditAsync(string ruleCode)
    {
        _edit.LowerLimit = ParseNullableDouble(_editLowerText);
        _edit.UpperLimit = ParseNullableDouble(_editUpperText);

        _loading = true;
        try
        {
            var result = await ApiClient.UpdateSpcRuleAsync(ruleCode, _edit);
            _message = $"{result.Code} - {result.Message}";

            if (result.Success)
            {
                CancelEdit();
                await LoadRulesAsync();
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private static double? ParseNullableDouble(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return null;
        }

        return double.TryParse(text, out var value) ? value : null;
    }
}
