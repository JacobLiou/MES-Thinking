@inherits LayoutComponentBase

<Layout ShowGotoTop="true" ShowCollapseBar="true" SideWidth="220" IsPage="true" IsFullSide="true">
    <Header>
        <span class="ms-3 fw-bold">MES 工站模拟终端</span>
    </Header>
    <Side>
        <div class="layout-menu">
            <Menu Items="_menus" IsVertical="true" IsAccordion="true" />
        </div>
    </Side>
    <Main>
        <div class="p-3">
            @Body
        </div>
    </Main>
</Layout>

@code {
    private readonly List<MenuItem> _menus =
    [
        new() { Text = "首页", Icon = "fa-solid fa-home", Url = "/" },
        new() { Text = "工站工作台", Icon = "fa-solid fa-industry", Url = "/station" },
        new() { Text = "工单", Icon = "fa-solid fa-clipboard-list", Url = "/work-orders" },
        new() { Text = "追溯", Icon = "fa-solid fa-search", Url = "/traceability" }
    ];
}
